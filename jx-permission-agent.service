[Unit]
Description=JX Sentinel Guard Permission Agent
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
PassEnvironment=DISPLAY WAYLAND_DISPLAY XDG_RUNTIME_DIR DBUS_SESSION_BUS_ADDRESS XDG_CURRENT_DESKTOP DESKTOP_SESSION
Environment=GDK_BACKEND=wayland,x11
ExecStart=/opt/jx/bin/jx-permission-agent
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
